{
  "manifest_version": 3,
  "name": "CFCoach",
  "version": "0.1.0",
  "description": "CFCoach brings Profile Analysis, Daily Mix, and Contest Generator directly to Codeforces.",
  "permissions": ["storage"],
  "host_permissions": [
    "*://codeforces.com/*",
    "*://*.codeforces.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_title": "CFCoach"
  },
  "content_scripts": [
    {
      "matches": ["*://codeforces.com/*", "*://*.codeforces.com/*"],
      "js": ["contentScript.js"],
      "css": ["contentScript.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["overlay.html", "overlay.css", "overlay.js"],
      "matches": ["*://codeforces.com/*", "*://*.codeforces.com/*"]
    }
  ]
}
